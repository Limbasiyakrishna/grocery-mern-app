                ]
              }
            }
          ]
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/user/send-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "send-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('OTP sent', () => pm.expect(pm.response.code).to.be.oneOf([200, 400]));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/user/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "verify-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response received', () => pm.expect(pm.response.code).to.be.oneOf([200, 400]));",
                  "const d = pm.response.json();",
                  "if (d.success && d.token) pm.collectionVariables.set('authToken', d.token);"
                ]
              }
            }
          ]
        }
      ]
