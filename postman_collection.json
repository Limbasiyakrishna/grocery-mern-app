{
  "info": {
    "name": "FreshNest Grocery MERN App – Full API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for the FreshNest Grocery MERN App. Base URL: http://127.0.0.1:5000. Use the 'FreshNest Dev' environment with variables: authToken, sellerToken, userId, orderId, productId, addressId, messageId."
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:5000", "type": "string" },
    { "key": "authToken",   "value": "", "type": "string" },
    { "key": "sellerToken", "value": "", "type": "string" },
    { "key": "userId",      "value": "", "type": "string" },
    { "key": "orderId",     "value": "", "type": "string" },
    { "key": "productId",   "value": "", "type": "string" },
    { "key": "addressId",   "value": "", "type": "string" },
    { "key": "messageId",   "value": "", "type": "string" },
    { "key": "couponCode",  "value": "SAVE10", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth – User",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/user/register",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const d = pm.response.json();",
                  "if (d.success && d.token) {",
                  "  pm.collectionVariables.set('authToken', d.token);",
                  "  pm.collectionVariables.set('userId', d.user?._id || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/user/login",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "if (d.success && d.token) {",
                  "  pm.collectionVariables.set('authToken', d.token);",
                  "  pm.collectionVariables.set('userId', d.user?._id || '');",
                  "}",
                  "// Also grab from cookie if token is cookie-based",
                  "const cookie = pm.response.headers.get('set-cookie');",
                  "if (cookie) {",
                  "  const m = /token=([^;]+)/.exec(cookie);",
                  "  if (m) pm.collectionVariables.set('authToken', m[1]);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Check Auth (Is Authenticated?)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "token={{authToken}}" }],
            "url": {
              "raw": "{{base_url}}/api/user/is-auth",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "is-auth"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Authenticated', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "token={{authToken}}" }],
            "url": {
              "raw": "{{base_url}}/api/user/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "logout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout success', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ]
        },
        {
