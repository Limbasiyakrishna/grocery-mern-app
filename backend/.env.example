# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/grocery-app

# Authentication
# Suggestion: Generate a 64-character hex string for production
JWT_SECRET=your_jwt_secret_here

# Admin / Seller Credentials
SELLER_EMAIL=admin@gmail.com
SELLER_PASSWORD=admin123

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Nodemailer / Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Client URL (for CORS)
FRONTEND_URL=http://localhost:5173

# PhonePe Payment Gateway
PHONEPE_MERCHANT_ID=your_merchant_id
PHONEPE_API_KEY=your_api_key
PHONEPE_SALT_KEY=your_salt_key

# UPI Configuration
UPI_ID=your_upi_id@bank

# Backend URL (for callbacks)
BACKEND_URL=http://localhost:5000
